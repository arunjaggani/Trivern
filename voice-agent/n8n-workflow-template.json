        {
            "parameters": {
                "jsCode": "// ─── Process Call Completion ────────────────────\n// Store call data and trigger WhatsApp confirmation if meeting was booked\n\nconst data = $input.first().json.body || $input.first().json;\n\nreturn [{\n  json: {\n    room: data.room,\n    callerNumber: data.callerNumber,\n    language: data.language,\n    duration: data.duration,\n    outcome: data.outcome,\n    leadTemperature: data.leadTemperature,\n    transcript: JSON.stringify(data.transcript || []),\n    source: 'voice',\n    shouldSendWhatsApp: data.outcome === 'booked',\n  }\n}];"
            },
            "id": "process-call-data",
            "name": "Process Call Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                500,
                1350
            ]
