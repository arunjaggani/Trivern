            "parameters": {
                "jsCode": "// ─── City → Language Detection ─────────────────\n// Maps the form's city field to Sarvam AI language code\n\nconst inputData = $input.first().json.body || $input.first().json;\nconst city = (inputData.city || '').toLowerCase().trim();\n\nconst CITY_LANGUAGE_MAP = {\n  // Telugu (te-IN)\n  'hyderabad': 'te-IN',\n  'secunderabad': 'te-IN',\n  'warangal': 'te-IN',\n  'vijayawada': 'te-IN',\n  'visakhapatnam': 'te-IN',\n  'vizag': 'te-IN',\n  'tirupati': 'te-IN',\n  'guntur': 'te-IN',\n  'nellore': 'te-IN',\n  'kurnool': 'te-IN',\n  'rajahmundry': 'te-IN',\n  'kakinada': 'te-IN',\n  'eluru': 'te-IN',\n  'karimnagar': 'te-IN',\n  'nizamabad': 'te-IN',\n  'khammam': 'te-IN',\n  'mahbubnagar': 'te-IN',\n  'rangareddy': 'te-IN',\n  'medak': 'te-IN',\n  'nalgonda': 'te-IN',\n\n  // Hindi (hi-IN)\n  'delhi': 'hi-IN',\n  'new delhi': 'hi-IN',\n  'mumbai': 'hi-IN',\n  'pune': 'hi-IN',\n  'jaipur': 'hi-IN',\n  'lucknow': 'hi-IN',\n  'kanpur': 'hi-IN',\n  'nagpur': 'hi-IN',\n  'indore': 'hi-IN',\n  'bhopal': 'hi-IN',\n  'patna': 'hi-IN',\n  'agra': 'hi-IN',\n  'varanasi': 'hi-IN',\n  'noida': 'hi-IN',\n  'gurgaon': 'hi-IN',\n  'gurugram': 'hi-IN',\n  'ahmedabad': 'hi-IN',\n  'surat': 'hi-IN',\n  'chandigarh': 'hi-IN',\n  'dehradun': 'hi-IN',\n  'faridabad': 'hi-IN',\n  'ghaziabad': 'hi-IN',\n  'ranchi': 'hi-IN',\n\n  // English (en-IN) — default for cosmopolitan cities\n  'bangalore': 'en-IN',\n  'bengaluru': 'en-IN',\n  'goa': 'en-IN',\n  'pondicherry': 'en-IN',\n  'puducherry': 'en-IN',\n};\n\nconst language = CITY_LANGUAGE_MAP[city] || 'en-IN';\n\nreturn [{\n  json: {\n    ...inputData,\n    language: language,\n    detectedCity: city,\n  }\n}];"
            },
            "id": "detect-language",
            "name": "Detect Language from City",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                470,
                300
            ]
