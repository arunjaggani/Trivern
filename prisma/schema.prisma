// Trivern Agency System — Prisma Schema
// Local dev: SQLite | Production (Hostinger): MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?  @unique // WhatsApp number — Zara uses this to recognize owner/employee
  role         String   @default("STAFF") // "ADMIN" | "MANAGER" | "STAFF"
  createdAt    DateTime @default(now())
}

// ─── Clients / Leads ────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  name         String
  company      String?
  email        String?
  phone        String   @unique  // Golden Record — one phone = one lead identity
  service      String?
  context      String?

  // Source
  source String? // "WhatsApp" | "Website" | "Voice" | "Referral"
  status String  @default("NEW") // NEW | CONTACTED | QUALIFIED | BOOKED | COMPLETED | LOST

  // Lead Scoring — 5 Pillars (100 total)
  score           Int  @default(0) // Composite score
  fitScore        Int  @default(0) // Max 20
  painScore       Int  @default(0) // Max 25
  intentScore     Int  @default(0) // Max 20
  authorityScore  Int  @default(0) // Max 20
  engagementScore Int  @default(0) // Max 15
  scoreOverride   Int? // Manual override by owner

  // Lead metadata
  industry     String?
  intent       String?
  painCategory String?
  budgetHint   String?
  urgency      String? // LOW | MEDIUM | HIGH | CRITICAL
  businessType String? // coach, clinic, consultant, etc.
  decisionRole String? // founder, owner, employee, assistant

  // Founder escalation
  escalated        Boolean @default(false)
  escalationReason String?

  notes   String?
  remarks String?

  meetings      Meeting[]
  conversations Conversation[]
  voiceCalls    VoiceCall[]
  activities    LeadActivity[]  // ← Full audit trail

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Lead Activity Timeline ──────────────────────────
// Every significant event in a lead's lifecycle.
// This is the "God View" data source — merges Chat, Voice, System events.
// Designed for future RAG/Postgres migration: all fields are plain scalars.

model LeadActivity {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Event classification
  type    String // STATUS_CHANGE | CALL_STARTED | CALL_ENDED | MEETING_BOOKED
                 // MEETING_COMPLETED | MESSAGE_RECEIVED | LEAD_SCORED | ESCALATED | NOTE_ADDED
  channel String // VOICE | CHAT | MANUAL | SYSTEM

  // Human-readable content (used in timeline UI)
  title  String  // "Meeting booked via Voice"
  detail String? // "Duration: 4m 32s · Outcome: booked · Score: 75 → 82"

  // Optional links to related records (nullable for clean schema)
  meetingId      String?
  voiceCallId    String?
  conversationId String?

  // Status change snapshot
  fromStatus String? // Previous client.status
  toStatus   String? // New client.status

  // Score snapshot at time of event
  scoreAtEvent Int?

  // Who/what triggered it
  triggeredBy String @default("SYSTEM") // "SYSTEM" | "ADMIN" | user name

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([createdAt])
}


// ─── Meetings ───────────────────────────────────────

model Meeting {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  date            DateTime
  duration        Int      @default(20) // minutes
  meetLink        String?
  calendarEventId String?

  status    String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED | NO_SHOW | RESCHEDULED
  attended  Boolean?
  remarks   String?
  highlights    String?
  requirements  String?
  outcome       String?
  recordingLink String?

  prepDocGenerated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Conversations ──────────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  messages      String   @db.LongText // JSON string: [{role, content, timestamp}]
  summary       String?
  status        String   @default("active")
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
}

// ─── Site Config ────────────────────────────────────

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique // "hero_title", "services", "faqs", etc.
  value     String   @db.LongText // JSON string
  updatedAt DateTime @updatedAt
}

// ─── Booking Settings ───────────────────────────────

model BookingSettings {
  id            String  @id @default(cuid())
  startHour     Int     @default(9)  // 9 AM
  endHour       Int     @default(21) // 9 PM
  slotDuration  Int     @default(30) // minutes
  bufferMinutes Int     @default(30)
  maxPerDay     Int     @default(6)
  blockedDates  String  @default("[]") // JSON string
  holidays      String  @default("[]") // JSON string
  automationOn  Boolean @default(true)
}

// ─── Blog ──────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.LongText // Markdown
  excerpt     String?
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  author      String    @default("Trivern")
  tags        String    @default("[]") // JSON array
  metaTitle   String?   // SEO
  metaDesc    String?   // SEO
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Voice Calls ────────────────────────────────────

model VoiceCall {
  id              String   @id @default(cuid())
  callerNumber    String
  roomName        String?  // LiveKit room name
  language        String   @default("en-IN")
  duration        Int      @default(0)  // seconds
  outcome         String   @default("unknown") // booked, whatsapp_followup, callback, no_answer, unknown
  leadTemperature String   @default("warm") // hot, warm, lukewarm, cold
  transcript      String?  @db.LongText // JSON array of {role, content, timestamp}
  summary         String?
  recordingUrl    String?
  callType        String   @default("outbound") // outbound, inbound

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
}
